    "dayjs": "^1.11.13",
    "framer-motion": "^11.12.0",
    "lodash": "^4.17.21",
    "next": "^14.2.30",
    "next-intl": "^3.25.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.53.2",
    "react-icons": "^5.3.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
